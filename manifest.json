{
  "manifest_version": 3,
  "name": "Verilens — Deepfake & Misinformation Detector",
  "version": "0.1.0",
  "description": "Detect AI-generated media and misinformation on social feeds. (M1: manual image deepfake check, mock backend.)",
  "permissions": ["storage"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://pbs.twimg.com/*",
    "https://www.instagram.com/*",
    "https://instagram.com/*",
    "https://*.cdninstagram.com/*",
    "https://www.facebook.com/*",
    "https://facebook.com/*",
    "https://*.fbcdn.net/*",
    "https://video.twimg.com/*",
    "https://*.ngrok-free.app/*",
    "https://*.ngrok.app/*",
    "https://*.ngrok-free.dev/*",
    "https://*.ngrok.io/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "icons": {
    "16":  "assets/images/icon16.png",
    "32":  "assets/images/icon32.png",
    "48":  "assets/images/icon48.png",
    "128": "assets/images/icon128.png"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.instagram.com/*",
        "https://www.facebook.com/*"
      ],
      "js": [
        "lib/config.local.js",
        "lib/hash.js",
        "lib/tiers.js",
        "content/adapters/twitter.js",
        "content/adapters/instagram.js",
        "content/adapters/facebook.js",
        "content/videoCapture.js",
        "content/badge.js",
        "content/actions.js",
        "content/filter.js",
        "content/content.js",
        "content/textSelection.js",
        "content/imageHover.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content/purchaseUnlock.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/styles.css", "assets/images/*"],
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.instagram.com/*",
        "https://www.facebook.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "Verilens",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "assets/images/icon16.png",
      "32":  "assets/images/icon32.png",
      "48":  "assets/images/icon48.png",
      "128": "assets/images/icon128.png"
    }
  }
}
