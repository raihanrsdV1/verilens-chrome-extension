{
  "manifest_version": 3,
  "name": "Verilens — Deepfake & Misinformation Detector",
  "version": "0.1.0",
  "description": "Detect AI-generated media and misinformation on social feeds. (M1: manual image deepfake check, mock backend.)",
  "permissions": ["storage"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://pbs.twimg.com/*",
    "https://www.instagram.com/*",
    "https://instagram.com/*",
    "https://*.cdninstagram.com/*",
    "https://www.facebook.com/*",
    "https://facebook.com/*",
    "https://*.fbcdn.net/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.instagram.com/*",
        "https://www.facebook.com/*"
      ],
      "js": [
        "lib/hash.js",
        "lib/tiers.js",
        "content/adapters/twitter.js",
        "content/adapters/instagram.js",
        "content/adapters/facebook.js",
        "content/badge.js",
        "content/actions.js",
        "content/filter.js",
        "content/content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/styles.css"],
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.instagram.com/*",
        "https://www.facebook.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "Verilens",
    "default_popup": "popup/popup.html"
  }
}
