# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# ---- Editors / IDEs ----
.vscode/
.idea/
*.swp
*.swo
*~
.history/

# ---- Logs & temp ----
*.log
npm-debug.log*
