# ---- Build / packaging output ----
# Chrome "Pack extension" produces these; never commit signed keys.
dist/
build/
*.zip
*.crx
*.pem

# ---- Environment / secrets ----
# Backend URLs/keys must never be committed.
.env
.env.*
!.env.example
lib/config.local.js
!lib/config.local.example.js

# ---- Local Claude / agent artifacts ----
.claude/
